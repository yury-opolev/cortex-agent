<Window x:Class="Cortex.Contained.Channels.Voice.VoiceOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cortex Voice"
        Width="156" Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Opacity="0"
        IsHitTestVisible="True">

    <Window.Resources>
        <!-- Color palette -->
        <Color x:Key="ListeningGreen">#FF4CAF50</Color>
        <Color x:Key="ListeningGreenDim">#FF2E7D32</Color>
        <Color x:Key="SpeakingBlue">#FF42A5F5</Color>
        <Color x:Key="SpeakingBlueDim">#FF1565C0</Color>
        <Color x:Key="ProcessingYellow">#FFFFC107</Color>
        <Color x:Key="PausedAmber">#FFFF9800</Color>
        <Color x:Key="StopRed">#FFE53935</Color>
        <Color x:Key="IdleGray">#FF616161</Color>
        <Color x:Key="PanelBackground">#E6212121</Color>
        <Color x:Key="PanelBorder">#80FFFFFF</Color>

        <SolidColorBrush x:Key="ListeningGreenBrush" Color="{StaticResource ListeningGreen}" />
        <SolidColorBrush x:Key="SpeakingBlueBrush" Color="{StaticResource SpeakingBlue}" />
        <SolidColorBrush x:Key="ProcessingYellowBrush" Color="{StaticResource ProcessingYellow}" />
        <SolidColorBrush x:Key="PausedAmberBrush" Color="{StaticResource PausedAmber}" />
        <SolidColorBrush x:Key="StopRedBrush" Color="{StaticResource StopRed}" />
        <SolidColorBrush x:Key="IdleGrayBrush" Color="{StaticResource IdleGray}" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackground}" />
        <SolidColorBrush x:Key="BarInactiveBrush" Color="#40FFFFFF" />
    </Window.Resources>

    <!-- Outer border = the pill-shaped panel -->
    <Border x:Name="RootPanel"
            CornerRadius="28"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            Padding="6,4"
            MouseLeftButtonDown="RootPanel_MouseLeftButtonDown"
            MouseRightButtonDown="RootPanel_MouseRightButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Main action button (mic / pause / play) -->
            <Button x:Name="ActionButton"
                    Grid.Column="0"
                    Width="40" Height="40"
                    Click="ActionButton_Click"
                    Cursor="Hand"
                    ToolTip="Click to toggle listening">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Glow effect behind button when active -->
                            <Ellipse x:Name="ButtonGlow"
                                     Width="44" Height="44"
                                     Opacity="0">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="{StaticResource ListeningGreen}" Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <!-- Main button circle -->
                            <Ellipse x:Name="ButtonCircle"
                                     Width="40" Height="40"
                                     Fill="{StaticResource IdleGrayBrush}"
                                     Stroke="#60FFFFFF"
                                     StrokeThickness="1.5" />

                            <!-- Microphone icon (shown during Listening, Processing, Idle) -->
                            <Canvas x:Name="MicIcon" Width="16" Height="22"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Canvas.Left="4" Canvas.Top="0"
                                           Width="8" Height="13"
                                           RadiusX="4" RadiusY="4"
                                           Fill="White" />
                                <Path Data="M 2,11 A 6,6 0 0 0 14,11"
                                      Stroke="White" StrokeThickness="1.8"
                                      Fill="Transparent" />
                                <Line X1="8" Y1="17" X2="8" Y2="20"
                                      Stroke="White" StrokeThickness="1.8" />
                                <Line X1="4" Y1="20" X2="12" Y2="20"
                                      Stroke="White" StrokeThickness="1.8" />
                            </Canvas>

                            <!-- Pause icon (shown during Speaking) -->
                            <Canvas x:Name="PauseIcon" Width="14" Height="16"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <Rectangle Canvas.Left="1" Canvas.Top="0"
                                           Width="4" Height="16"
                                           RadiusX="1" RadiusY="1"
                                           Fill="White" />
                                <Rectangle Canvas.Left="9" Canvas.Top="0"
                                           Width="4" Height="16"
                                           RadiusX="1" RadiusY="1"
                                           Fill="White" />
                            </Canvas>

                            <!-- Play icon (shown during Paused) -->
                            <Canvas x:Name="PlayIcon" Width="14" Height="16"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <Path Data="M 2,0 L 14,8 L 2,16 Z"
                                      Fill="White" />
                            </Canvas>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Equalizer bars container -->
            <Canvas x:Name="EqualizerCanvas"
                    Grid.Column="1"
                    Width="44" Height="32"
                    Margin="6,0,4,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <!-- Bar 1 (left) -->
                <Rectangle x:Name="Bar1"
                           Canvas.Left="4" Canvas.Top="26"
                           Width="8" Height="6"
                           RadiusX="2" RadiusY="2"
                           Fill="{StaticResource BarInactiveBrush}" />

                <!-- Bar 2 (center) -->
                <Rectangle x:Name="Bar2"
                           Canvas.Left="18" Canvas.Top="26"
                           Width="8" Height="6"
                           RadiusX="2" RadiusY="2"
                           Fill="{StaticResource BarInactiveBrush}" />

                <!-- Bar 3 (right) -->
                <Rectangle x:Name="Bar3"
                           Canvas.Left="32" Canvas.Top="26"
                           Width="8" Height="6"
                           RadiusX="2" RadiusY="2"
                           Fill="{StaticResource BarInactiveBrush}" />
            </Canvas>

            <!-- Stop button (visible only during Speaking/Paused) -->
            <Button x:Name="StopButton"
                    Grid.Column="2"
                    Width="28" Height="28"
                    Margin="0,0,2,0"
                    Click="StopButton_Click"
                    Cursor="Hand"
                    ToolTip="Stop speaking"
                    Visibility="Collapsed">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Width="28" Height="28"
                                     Fill="#40E53935"
                                     Stroke="#60FFFFFF"
                                     StrokeThickness="1" />
                            <!-- Square stop icon -->
                            <Rectangle Width="10" Height="10"
                                       RadiusX="1" RadiusY="1"
                                       Fill="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
