{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MemoryMcp": {
    "DataDirectory": "/app/state/memory",
    "DuplicateThreshold": 0.90,
    "Ollama": {
      "Endpoint": "http://ollama:11434",
      "Model": "qwen3-embedding:0.6b",
      "Dimensions": 1024
    }
  },
  "MemoryCompaction": {
    "Enabled": true,
    "PreferredTimeOfDay": "03:00",
    "IntervalHours": 24,
    "SimilarityThreshold": 0.7
  }
}
