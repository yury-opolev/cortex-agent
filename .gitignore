## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Claude Code local settings
.claude/

# Git worktrees
.worktrees/

# Superpowers local workflow artifacts (specs under docs/superpowers/ are tracked)
.superpowers/

# Eval results (SQLite databases, transcripts)
**/eval-results/*.db
**/eval-results/*.db-shm
**/eval-results/*.db-wal
**/eval-results/*.transcript.json

# Local settings overrides (may contain secrets)
appsettings.*.local.json

# Code signing certificates
*.pfx

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# Visual Studio
*.vsp
*.vspx
.vs/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Speech/ML model files (downloaded at build time, too large for git)
*.onnx
*.bin
*.ggml
models/

# Legacy: cortex.yml used to be written to content root before being moved to %LOCALAPPDATA%\Cortex
cortex.yml

# Playwright MCP session artifacts (screenshots, snapshots, console logs)
.playwright-mcp/
build-*.log

# coda runtime state when a coding session runs in this repo (transcripts, cache)
.coda/
